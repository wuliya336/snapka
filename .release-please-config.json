{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": true,
  "always-link-local": true,
  "plugins": [
    {
      "type": "node-workspace"
    }
  ],
  "changelog-sections": [
    {
      "type": "feat",
      "section": "✨ Features",
      "hidden": false
    },
    {
      "type": "fix",
      "section": "🐛 Bug Fixes",
      "hidden": false
    },
    {
      "type": "perf",
      "section": "⚡️ Performance",
      "hidden": false
    },
    {
      "type": "revert",
      "section": "⏪️ Reverts",
      "hidden": false
    },
    {
      "type": "docs",
      "section": "📝 Documentation",
      "hidden": false
    },
    {
      "type": "style",
      "section": "💄 Styles",
      "hidden": false
    },
    {
      "type": "chore",
      "section": "🎫 Chores",
      "hidden": false
    },
    {
      "type": "refactor",
      "section": "♻️ Code Refactoring",
      "hidden": false
    },
    {
      "type": "test",
      "section": "✅ Tests",
      "hidden": false
    },
    {
      "type": "build",
      "section": "📦️ Build System",
      "hidden": false
    },
    {
      "type": "ci",
      "section": "🎡 Continuous Integration",
      "hidden": false
    }
  ],
  "packages": {
    "packages/snapka-types": {
      "release-type": "node",
      "package-name": "@snapka/types",
      "component": "types",
      "tag-separator": "-",
      "scope": "types"
    },
    "packages/puppeteer-browsers": {
      "release-type": "node",
      "package-name": "@snapka/browsers",
      "component": "browsers",
      "tag-separator": "-",
      "scope": "browsers"
    },
    "packages/browser-finder": {
      "release-type": "node",
      "package-name": "@snapka/browser-finder",
      "component": "browser-finder",
      "tag-separator": "-",
      "scope": "browser-finder"
    },
    "packages/playwright": {
      "release-type": "node",
      "package-name": "@snapka/playwright",
      "component": "playwright",
      "tag-separator": "-",
      "scope": "playwright"
    },
    "packages/puppeteer": {
      "release-type": "node",
      "package-name": "@snapka/puppeteer",
      "component": "puppeteer",
      "tag-separator": "-",
      "scope": "puppeteer"
    }
  },
  "commit-search-depth": 50
}