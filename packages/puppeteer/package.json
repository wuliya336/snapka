{
  "name": "@snapka/puppeteer",
  "version": "0.2.7",
  "description": "Enhanced Puppeteer with browser finder and parallel screenshot capabilities",
  "keywords": [
    "puppeteer",
    "browser",
    "automation",
    "testing",
    "screenshot",
    "parallel",
    "chromium",
    "chrome",
    "headless"
  ],
  "homepage": "https://github.com/karinjs/snapka#readme",
  "bugs": {
    "url": "https://github.com/karinjs/snapka/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KarinJS/snapka.git",
    "directory": "packages/puppeteer"
  },
  "license": "MIT",
  "author": "shijin",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./puppeteer-core": "./src/puppeteer-core.ts",
    "./snapka-browser-finder": "./src/snapka-browser-finder.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@snapka/browser-finder": "workspace:*",
    "@snapka/browsers": "workspace:*",
    "@snapka/types": "workspace:*",
    "debug": "^4.4.3",
    "p-limit": "catalog:",
    "puppeteer-core": "^24.31.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "./puppeteer-core": {
        "types": "./dist/puppeteer-core.d.ts",
        "default": "./dist/puppeteer-core.mjs"
      },
      "./snapka-browser-finder": {
        "types": "./dist/snapka-browser-finder.d.ts",
        "default": "./dist/snapka-browser-finder.mjs"
      }
    }
  },
  "access": "public",
  "devDependencies": {
    "@types/debug": "4.1.12"
  }
}