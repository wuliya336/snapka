{
  "name": "@snapka/playwright",
  "version": "0.2.4",
  "description": "Enhanced Playwright with browser finder and parallel screenshot capabilities",
  "keywords": [
    "playwright",
    "browser",
    "automation",
    "testing",
    "screenshot",
    "parallel",
    "chromium",
    "firefox",
    "webkit"
  ],
  "homepage": "https://github.com/karinjs/snapka#readme",
  "bugs": {
    "url": "https://github.com/karinjs/snapka/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KarinJS/snapka.git",
    "directory": "packages/playwright"
  },
  "license": "MIT",
  "author": "shijin",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./playwright-core": "./src/playwright-core.ts",
    "./snapka-browser-finder": "./src/snapka-browser-finder.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@snapka/browser-finder": "workspace:*",
    "@snapka/browsers": "workspace:*",
    "@snapka/types": "workspace:*",
    "debug": "^4.4.3",
    "p-limit": "catalog:",
    "playwright-core": "^1.56.1"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "./playwright-core": {
        "types": "./dist/playwright-core.d.ts",
        "default": "./dist/playwright-core.mjs"
      },
      "./snapka-browser-finder": {
        "types": "./dist/snapka-browser-finder.d.ts",
        "default": "./dist/snapka-browser-finder.mjs"
      }
    }
  },
  "access": "public",
  "devDependencies": {
    "@types/debug": "4.1.12"
  }
}